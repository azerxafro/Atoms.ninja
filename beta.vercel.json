{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "api/beta.js",
            "use": "@vercel/node"
        },
        {
            "src": "lib/mcp-servers.js",
            "use": "@vercel/node"
        },
        {
            "src": "lib/lab-sandbox.js",
            "use": "@vercel/node"
        },
        {
            "src": "lib/self-trainer.js",
            "use": "@vercel/node"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "styles.css",
            "use": "@vercel/static"
        },
        {
            "src": "config.js",
            "use": "@vercel/static"
        },
        {
            "src": "shared-config.js",
            "use": "@vercel/static"
        },
        {
            "src": "speed-insights.js",
            "use": "@vercel/static"
        },
        {
            "src": "favicon.png",
            "use": "@vercel/static"
        },
        {
            "src": "logo.png",
            "use": "@vercel/static"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/beta/mcp/(.*)",
            "methods": [
                "GET",
                "POST",
                "OPTIONS"
            ],
            "dest": "/api/beta.js",
            "headers": {
                "Access-Control-Allow-Origin": "*",
                "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type, Authorization",
                "Access-Control-Max-Age": "86400"
            }
        },
        {
            "src": "/api/beta/lab/(.*)",
            "methods": [
                "GET",
                "POST",
                "OPTIONS"
            ],
            "dest": "/api/beta.js",
            "headers": {
                "Access-Control-Allow-Origin": "*"
            }
        },
        {
            "src": "/api/beta/train/(.*)",
            "methods": [
                "GET",
                "POST",
                "OPTIONS"
            ],
            "dest": "/api/beta.js",
            "headers": {
                "Access-Control-Allow-Origin": "*"
            }
        },
        {
            "src": "/api/mcp/(.*)",
            "methods": [
                "GET",
                "POST",
                "OPTIONS"
            ],
            "dest": "/api/index.js",
            "headers": {
                "Access-Control-Allow-Origin": "*",
                "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type, Authorization",
                "Access-Control-Max-Age": "86400"
            }
        },
        {
            "src": "/api/lab/(.*)",
            "methods": [
                "GET",
                "POST",
                "OPTIONS"
            ],
            "dest": "/api/index.js",
            "headers": {
                "Access-Control-Allow-Origin": "*"
            }
        },
        {
            "src": "/api/train/(.*)",
            "methods": [
                "GET",
                "POST",
                "OPTIONS"
            ],
            "dest": "/api/index.js",
            "headers": {
                "Access-Control-Allow-Origin": "*"
            }
        },
        {
            "src": "/api/(.*)",
            "methods": [
                "OPTIONS"
            ],
            "dest": "/api/index.js",
            "headers": {
                "Access-Control-Allow-Origin": "*",
                "Access-Control-Allow-Methods": "GET, POST, PUT, DELETE, OPTIONS",
                "Access-Control-Allow-Headers": "Content-Type, Authorization",
                "Access-Control-Max-Age": "86400"
            }
        },
        {
            "src": "/api/auth/(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/(.*)",
            "dest": "/api/index.js",
            "headers": {
                "Access-Control-Allow-Origin": "*"
            }
        },
        {
            "src": "/(.*)",
            "dest": "/$1"
        }
    ],
    "env": {
        "NODE_ENV": "production",
        "ENABLE_BETA_FEATURES": "true",
        "LAB_TYPE": "local",
        "LAB_AUTO_CLEANUP": "true",
        "TRAINING_MAX_ITERATIONS": "5",
        "TRAINING_PARALLEL": "2"
    }
}