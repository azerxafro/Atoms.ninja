{
  "name": "atoms-ninja-backend",
  "version": "1.0.0",
  "description": "Unified AI + Kali Security Backend for Atoms Ninja",
  "main": "atoms-server.js",
  "scripts": {
    "start": "node atoms-server.js",
    "start:arsenal": "node atoms-server.js",
    "dev": "nodemon atoms-server.js",
    "dev:arsenal": "nodemon atoms-server.js",
    "test": "node atoms-server.js & sleep 2 && node test.js",
    "test:full": "node atoms-server.js & sleep 3 && node test-api-and-mcp.js",
    "test:api": "node test-api-and-mcp.js",
    "validate": "node validate-config.js",
    "demo": "node demo-system.js",
    "fetch-ips": "bash scripts/fetch-ip-ranges.sh",
    "secure-sg": "bash scripts/update-security-group.sh",
    "setup-waf": "bash scripts/setup-aws-waf.sh",
    "audit-ips": "bash scripts/fetch-ip-ranges.sh && cat ip-attribution.json"
  },
  "keywords": [
    "openrouter",
    "proxy",
    "cybersecurity",
    "atoms-ninja"
  ],
  "author": "Atoms Ninja Team",
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-bedrock-runtime": "^3.600.0",
    "@vercel/analytics": "^1.5.0",
    "@vercel/speed-insights": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "express-rate-limit": "^7.5.0",
    "googleapis": "^171.4.0",
    "node-fetch": "^2.7.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
